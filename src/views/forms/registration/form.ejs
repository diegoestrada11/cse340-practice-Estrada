<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>
        Register for a new account by providing your information below. All fields are required and passwords must meet security requirements.
    </p>

    <% if (errors && errors.length > 0) { %>
        <div class="error-messages">
            <ul>
                <% errors.forEach(error => { %>
                    <li><%= error.msg %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form method="POST" action="/register" class="registration-form">
        <!-- Name field -->
        <div class="form-group">
            <label for="name">Name</label>
            <input 
                type="text" 
                id="name" 
                name="name" 
                minlength="2" 
                required 
                placeholder="Enter your full name">
        </div>

        <!-- Email field -->
        <div class="form-group">
            <label for="email">Email Address</label>
            <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="Enter your email address">
        </div> 

        <!-- Email confirmation field -->
        <div class="form-group">
            <label for="emailConfirmation">Confirm Email</label>
            <input 
                type="email"
                id="emailConfirmation"
                name="emailConfirm"
                required
                placeholder="Re-enter your email address">
        </div> 
    
        <!-- Password field -->
        <div class="form-group ">
            <label for="password">Password</label>
            <input 
                type="password" 
                id="password" 
                name="password" 
                minlength="8" 
                required 
                pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" 
                placeholder="Create a strong password">
            <div class="help-text">
                Must be at least 8 characters with a number and special character
            </div>

        </div> 

        <!-- Password confirmation field -->
        <div class="form-group">
            <label for="passwordConfirm">Password Confirmation</label>
            <input type="password"
            id="passwordConfirm"
            name="passwordConfirm"
            required
            placeholder="Re-enter your password">
        </div>

        <!-- Submit button -->
        <div class="form-group">
            <button type="submit">Create Account</button>

        </div>

    </form>
</main>
<%- include('../../partials/footer') %>