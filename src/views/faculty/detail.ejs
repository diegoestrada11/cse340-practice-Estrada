<%- include('../partials/header') %>

<main class="faculty-detail-container">
    <h1><%= faculty.name %></h1>
    <p class="faculty-title"><em><%= faculty.title %></em></p>

    <section class="faculty-info">
        <p><strong>Department:</strong> <%= faculty.department %></p>
        <p><strong>Office:</strong> <%= faculty.office %></p>
        <p><strong>Phone:</strong> <%= faculty.phone %></p>
        <p><strong>Email:</strong> 
            <a href="mailto:<%= faculty.email %>"><%= faculty.email %></a>
        </p>
    </section>

    <div class="faculty-navigation">
        <a href="/faculty" class="back-link">← Back to Faculty List</a>
    </div>
</main>

<%- include('../partials/footer') %>
